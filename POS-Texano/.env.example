# ============================================
# POS-Texano - Variables de Entorno
# ============================================

# Base de Datos (MariaDB en VPS)
# Si la BD está en el VPS y el backend también, usa: DB_HOST=localhost
# Si la BD está en otro servidor, usa la IP/dominio: DB_HOST=tu-vps.com
# Si corres Docker en tu máquina y la BD está en el host, usa: DB_HOST=host.docker.internal
DB_HOST=localhost
DB_PORT=3306
DB_USER=pos_texano
DB_PASSWORD=tu_password_seguro
DB_NAME=pos_texano

# JWT
JWT_SECRET=tu_secreto_jwt_super_seguro_cambiar_en_produccion
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=480

# Admin por defecto (seed)
ADMIN_EMAIL=admin@texano.com
ADMIN_PASSWORD=admin123
ADMIN_NOMBRE=Administrador
ADMIN_APELLIDO=Texano

# Servidor
APP_HOST=0.0.0.0
APP_PORT=8000
APP_RELOAD=true


